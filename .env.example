# ==========================================================================
# CMC Alumni Hub — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored.
# ==========================================================================

# ---- Spring profile: local | prod ----
APP_PROFILE=local

# ---- Database ----------------------------------------------------------
# LOCAL: the dockerised postgres below is used automatically.
#        Compose passes these to the postgres container too.
POSTGRES_DB=alumnihub
POSTGRES_USER=alumnihub
POSTGRES_PASSWORD=alumnihub

# Backend datasource. In local compose, host is the `postgres` service.
DB_URL=jdbc:postgresql://postgres:5432/alumnihub
DB_USERNAME=alumnihub
DB_PASSWORD=alumnihub

# PROD: point at your cloud PostgreSQL and REQUIRE SSL, e.g. (Neon example):
#   DB_URL=jdbc:postgresql://ep-xxx.eu-central-1.aws.neon.tech:5432/alumnihub?sslmode=require
#   DB_USERNAME=...
#   DB_PASSWORD=...

# ---- JWT (REQUIRED in prod; must be long & random) ---------------------
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-characters-long-000
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# ---- Initial admin (created on first start if no admin exists) ----------
# In PRODUCTION set a strong password here.
ADMIN_EMAIL=admin@cmc.msu.ru
ADMIN_PASSWORD=admin123

# ---- Demo data ---------------------------------------------------------
# true  -> load demo alumni/cards/questions on first start (showcase)
# false -> clean start: only bootstrap admin + reference tags (PRODUCTION)
APP_SEED_DEMO=true

# ---- Frontend URL (used for invite links & CORS) -----------------------
APP_FRONTEND_URL=http://localhost:5173

# ---- Invites -----------------------------------------------------------
INVITE_EXPIRY_DAYS=7

# ---- SMTP (real email sending) -----------------------------------------
# Example for Yandex: smtp.yandex.ru / 587 ; for Gmail: smtp.gmail.com / 587
# Use an app password, not your account password.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=CMC Alumni Hub <no-reply@cmc-alumni-hub.local>

# ---- Photo storage -----------------------------------------------------
STORAGE_UPLOAD_DIR=./uploads

# ---- Moderation --------------------------------------------------------
MODERATION_PROVIDER=rule-based
MODERATION_AI_API_URL=
MODERATION_AI_API_KEY=

# ---- Frontend build (Vite) ---------------------------------------------
VITE_API_URL=http://localhost:8080/api
